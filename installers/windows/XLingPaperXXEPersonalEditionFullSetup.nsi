!define MUI_UNFINISHPAGE_NOAUTOCLOSE

# Included files
!include Sections.nsh
!include MUI2.nsh
     ; include for some of the windows messages defines
!include "winmessages.nsh"
!include FontRegAdv.nsh
#!include FontName.nsh
!include FontInstall.nsh

# Variables
Var StartMenuGroup
Var /GLOBAL XXE_command_line
Var /GLOBAL XXE_bin_path

# Installer pages
!define MUI_WELCOMEPAGE_TEXT "This wizard will guide you through the installation of the Personal Edition of the XMLmind XML Editor and XLingPaper.$\r$\n$\r$\nClick Next to continue."
!insertmacro MUI_PAGE_WELCOME
!insertmacro MUI_PAGE_LICENSE "..\LicenseInstaller\XXEPersonalAndXLingPaperLicense.txt"
!insertmacro MUI_PAGE_DIRECTORY
!insertmacro MUI_PAGE_INSTFILES
!define MUI_FINISHPAGE_TEXT "The Personal Edition of the XMLmind XML Editor and also XLingPaper have been installed on your computer.$\r$\n$\r$\n\
Unless you are a regular XLingPaper user, we highly recommend that you leave the following check box checked.  Note that it may take a little while before the program starts.  Please be patient."
!define MUI_FINISHPAGE_RUN
!define MUI_FINISHPAGE_RUN_TEXT "Start the program with a sample paper."
!define MUI_FINISHPAGE_RUN_FUNCTION "launchXXEWithSamplePaper"
!insertmacro MUI_PAGE_FINISH
!insertmacro MUI_UNPAGE_CONFIRM
!insertmacro MUI_UNPAGE_INSTFILES

# Installer languages
!insertmacro MUI_LANGUAGE English

# Installer attributes
OutFile XLingPaper${VERSION}XXEPersonalEditionFullSetup.exe
InstallDir $PROGRAMFILES\XLingPaper
CRCCheck on
XPStyle on
ShowInstDetails hide
VIProductVersion "${VERSION}"
VIAddVersionKey ProductName "XLingPaper Configuraton for the Personal Edition of the XMLmind XML Editor"
VIAddVersionKey ProductVersion "${VERSION}"
VIAddVersionKey CompanyName "${COMPANY}"
VIAddVersionKey CompanyWebsite "${URL}"
VIAddVersionKey FileVersion "${VERSION}"
VIAddVersionKey FileDescription ""
VIAddVersionKey LegalCopyright ""
InstallDirRegKey HKLM "${REGKEY}" Path
ShowUninstDetails hide

# Installer sections
Section -Main SEC0000
    SetOutPath $INSTDIR\XXEPersonalEditionInstaller
    SetOverwrite on
    File /r ..\XXE8Installer\*
    SetOutPath $APPDATA\XMLmind\XMLEditor8
    File /r /x .svn ..\XXE8Installer\preferences.properties
