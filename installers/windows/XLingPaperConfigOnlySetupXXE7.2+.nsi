# Installer languages
!insertmacro MUI_LANGUAGE English

# Installer attributes
OutFile XLingPaper${VERSION}UpdateConfigOnlySetup.exe
InstallDir $APPDATA\XMLmind\XMLEditor7\addon\XLingPap
CRCCheck on
XPStyle on
ShowInstDetails hide
VIProductVersion "${VERSION}"
VIAddVersionKey ProductName XLingPaper
VIAddVersionKey ProductVersion "${VERSION}"
VIAddVersionKey CompanyName "${COMPANY}"
VIAddVersionKey CompanyWebsite "${URL}"
VIAddVersionKey FileVersion "${VERSION}"
VIAddVersionKey FileDescription ""
VIAddVersionKey LegalCopyright ""
InstallDirRegKey HKLM "${REGKEY}" Path
ShowUninstDetails hide

# Installer sections
Section -Main SEC0000
   ; HKLM (all users) vs HKCU (current user) defines
   !define env_hklm 'HKLM "SYSTEM\CurrentControlSet\Control\Session Manager\Environment"'
   ; Find XXE info
   !define env_hkcu_xxe 'HKCU "Software\Classes\Applications\xxe.exe\shell\open\command"'
    ReadRegStr $9 ${env_hkcu_xxe} ""
    StrCmp $9 "" try2 HasXXE
    try2:
   !define env_hkcr_xxeXmlFile 'HKCR "XXE_XML_File\shell\open\command"'
    ReadRegStr $9 ${env_hkcr_xxeXmlFile} ""
    StrCmp $9 "" try3 HasXXE
    try3:
   !define env_hkcr_xxeXmlFileVista64 'HKCR "Wow6432Node\XXE_XML_File\shell\open\command"'
    ReadRegStr $9 ${env_hkcr_xxeXmlFileVista64} ""
    StrCmp $9 "" noXXE HasXXE
    noXXE:
    MessageBox MB_ICONEXCLAMATION|MB_OK "I cannot find the XMLmind XML Editor.  Please install it before trying to install the XLingPaper configuration files.\
See http://www.xmlmind.com/xmleditor/ and download the appropriate version for you." IDOK
    quit
    HasXXE:
;   !define env_hkcu_xelatex 'HKLM "SYSTEM\CurrentControlSet\Control\Session Manager\Environment"'
    ReadRegStr $9 ${env_hklm} "XLingPaperXeLaTeXPath"
    StrCmp $9 "" XLingPaperNotInstalled HasXeLaTeXEnvVar
    HasXeLaTeXEnvVar:
; now check to see if the files are actually there
    StrCpy $xelatexExe '$9\xelatex.exe'
    IfFileExists "$9\xelatex.exe" AssumeIsOK XLingPaperNotInstalled  
    XLingPaperNotInstalled:
    MessageBox MB_ICONEXCLAMATION|MB_OK "It appears that XLingPaper has not previously been installed.$\r$\n$\r$\n\
Please get the full XLingPaper installation package and run it." IDOK
    quit
    AssumeIsOK:
    ; at least xelatex.exe is there, so we'll assume the other files are, too.
    
