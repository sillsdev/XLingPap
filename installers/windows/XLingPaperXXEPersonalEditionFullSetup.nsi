#    ZipDLL::extractall "$INSTDIR\XXEPersonalEditionInstaller\fr_translation-7_6_0.zip" $APPDATA\XMLmind\XMLEditor8\addon
    ExecWait '"$INSTDIR\XXEPersonalEditionInstaller\xxe-perso-8_2_0-setup.exe"  /SILENT'
   ; HKLM (all users) vs HKCU (current user) defines
   !define env_hklm 'HKLM "SYSTEM\CurrentControlSet\Control\Session Manager\Environment"'
   ; Find XXE info
   !define env_hkcu_xxe 'HKCU "Software\Classes\Applications\xxe.exe\shell\open\command"'
    ReadRegStr $9 ${env_hkcu_xxe} ""
    StrCmp $9 "" try2 HasXXE
    try2:
   !define env_hkcr_xxeXmlFile 'HKCR "XXE_XML_File\shell\open\command"'
    ReadRegStr $9 ${env_hkcr_xxeXmlFile} ""
    StrCmp $9 "" try3 HasXXE
    try3:
   !define env_hkcr_xxeXmlFileVista64 'HKCR "Wow6432Node\XXE_XML_File\shell\open\command"'
    ReadRegStr $9 ${env_hkcr_xxeXmlFileVista64} ""
    StrCmp $9 "" try4 HasXXE
    try4:
    IfFileExists $APPDATA\XMLmind\XMLEditor7 hasXXE try5
    try5:
    IfFileExists $APPDATA\XMLmind\XMLEditor8 hasXXE noXXE
    noXXE:
    MessageBox MB_ICONEXCLAMATION|MB_OK "I cannot find the XMLmind XML Editor.  Please install it before trying to install XLingPaper$\r$\nSee http://www.xmlmind.com/xmleditor/ and download the appropriate version for you." IDOK
    quit
    HasXXE:
    ;; do not want the final 4 characters ("%1")
    StrCpy $XXE_command_line $9 -4
    ; do not want the final part: /xxe.exe
    StrCpy $7 $XXE_command_line -10
    ; do not want the initial quote
    StrCpy $XXE_bin_path $7 "" 1
# Remove any information from previous installations
    IfFileExists $APPDATA\XMLmind\XMLEditor7 0 +3
    RmDir /r $APPDATA\XMLmind\XMLEditor7\addon\XLingPap
    RmDir /r $APPDATA\XMLmind\XMLEditor7\cache
    IfFileExists $APPDATA\XMLmind\XMLEditor8 0 +3
    RmDir /r $APPDATA\XMLmind\XMLEditor8\addon\XLingPap
    RmDir /r $APPDATA\XMLmind\XMLEditor8\cache
    RmDir /r $INSTDIR\XeLaTeX
    RmDir /r $INSTDIR\XXE
       ; delete environment variables
   DeleteRegValue ${env_hklm} XLingPaperXeLaTeXPath
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
   DeleteRegValue ${env_hklm} XLingPaperXXEBinPath
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
# Now install the new stuff
    SetOutPath $APPDATA\XMLmind\XMLEditor8
    File /r /x .svn ..\XXE8Installer\preferences.properties
    #           XXE custom
#    SetOutPath $INSTDIR\XXE
#    SetOverwrite on
#    File /r /x .svn XXE\*
    #           XeLaTeX
    SetOutPath $INSTDIR\XeLaTeX
    SetOverwrite on
    File /r /x .svn XeLaTeX\*
    #           XLingPaper
    SetOutPath "$DOCUMENTS\My XLingPaper"
    File /r /x .svn ..\XLingPaperSamples\*
    #           Set two environment variables
   # !define env_hkcu 'HKCU "Environment"'
   WriteRegExpandStr ${env_hklm} XLingPaperXeLaTeXPath  $INSTDIR\XeLaTeX\bin\win32
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
   WriteRegExpandStr ${env_hklm} XLingPaperXXEBinPath  $XXE_bin_path
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
    #           XLingPaper configuration files
    ;SetOutPath $INSTDIR\XLingPaperConfiguration # for testing on my machine
    IfFileExists $APPDATA\XMLmind\XMLEditor7 0 +3
    SetOutPath $APPDATA\XMLmind\XMLEditor7\addon
    File /r  /x .svn ..\..\XLingPaperConfiguration\* 
    IfFileExists $APPDATA\XMLmind\XMLEditor8 0 +3
    SetOutPath $APPDATA\XMLmind\XMLEditor8\addon
    File /r  /x .svn ..\..\XLingPaperConfiguration\* 
    WriteRegStr HKLM "${REGKEY}\Components" Main 1
    # Make sure the small caps fonts are installed
    SetOutPath $INSTDIR\Fonts
    SetOverwrite on
    File /r /x .svn ..\Fonts\*
    StrCpy $FONT_DIR $FONTS
    !insertmacro FontInstallTTF "..\Fonts\CharisSILR_sc.ttf" "CharisSILR_sc.ttf" "Charis SIL Small Caps"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILB_sc.ttf" "CharisSILB_sc.ttf" "Charis SIL Small Caps Bold"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILBI_sc.ttf" "CharisSILBI_sc.ttf" "Charis SIL Small Caps Bold Italic"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILI_sc.ttf" "CharisSILI_sc.ttf" "Charis SIL Small Caps Italic"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILR-CompactSmallCaps.ttf" "CharisSILR-CompactSmallCaps.ttf" "Charis SIL CompactSmallCaps"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILB-CompactSmallCaps.ttf" "CharisSILB-CompactSmallCaps.ttf" "Charis SIL CompactSmallCaps Bold"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILBI-CompactSmallCaps.ttf" "CharisSILBI-CompactSmallCaps.ttf" "Charis SIL CompactSmallCaps Bold Italic"
    !insertmacro FontInstallTTF "..\Fonts\CharisSILI-CompactSmallCaps.ttf" "CharisSILI-CompactSmallCaps.ttf" "Charis SIL CompactSmallCaps Italic"
