#    !insertmacro InstallTTF "..\Fonts\CharisSILI-CompactSmallCaps.ttf"
    # XXE Peresonal Edition installer files no longer needed
    RmDir /r $INSTDIR\XXEPersonalEditionInstaller
SectionEnd

Section -post SEC0001
    Var /GLOBAL XXEShortcut
    WriteRegStr HKLM "${REGKEY}" Path $INSTDIR
    SetOutPath $INSTDIR
    WriteUninstaller $INSTDIR\XLingPaperUninstall.exe
    SetOutPath $SMPROGRAMS\$StartMenuGroup
    StrCpy $9 $XXE_command_line "" 3
    StrCpy $XXEShortcut $9 -2
    CreateShortCut "$SMPROGRAMS\$StartMenuGroup\Uninstall $(^Name).lnk" $INSTDIR\XLingPaperUninstall.exe
    CreateShortCut "$SMPROGRAMS\$StartMenuGroup\Launch XXE To Edit an XLingPaper Document.lnk" '$XXEShortcut' 
    CreateShortCut "$SMPROGRAMS\$StartMenuGroup\New XLingPaper Book.lnk" '$XXEShortcut' '-putpref locale en -new "An XLingPaper File/Complete Document" "Book (Chapter-oriented)" UntitledBook.xml' 
    CreateShortCut "$SMPROGRAMS\$StartMenuGroup\New XLingPaper Paper.lnk" '$XXEShortcut' '-putpref locale en -new "An XLingPaper File/Complete Document" "Paper (Section-oriented)" UntitledPaper.xml' 
    CreateShortCut "$SMPROGRAMS\$StartMenuGroup\New XLingPaper References.lnk" '$XXEShortcut' '-putpref locale en -new "An XLingPaper File/Document Component" "References (part of a modular document)" UntitledReferences.xml' 
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" DisplayName "$(^Name)"
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" DisplayVersion "${VERSION}"
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" Publisher "${COMPANY}"
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" URLInfoAbout "${URL}"
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" DisplayIcon $INSTDIR\XLingPaperUninstall.exe
    WriteRegStr HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" UninstallString $INSTDIR\XLingPaperUninstall.exe
    WriteRegDWORD HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" NoModify 1
    WriteRegDWORD HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)" NoRepair 1
SectionEnd

# Macro for selecting uninstaller sections
!macro SELECT_UNSECTION SECTION_NAME UNSECTION_ID
    Push $R0
    ReadRegStr $R0 HKLM "${REGKEY}\Components" "${SECTION_NAME}"
    StrCmp $R0 1 0 next${UNSECTION_ID}
    !insertmacro SelectSection "${UNSECTION_ID}"
    GoTo done${UNSECTION_ID}
next${UNSECTION_ID}:
    !insertmacro UnselectSection "${UNSECTION_ID}"
done${UNSECTION_ID}:
    Pop $R0
!macroend

# Uninstaller sections
Section /o -un.Main UNSEC0000
    IfFileExists $APPDATA\XMLmind\XMLEditor7 0 +1
    RmDir /r $APPDATA\XMLmind\XMLEditor7\addon\XLingPap
    IfFileExists $APPDATA\XMLmind\XMLEditor8 0 +1
    RmDir /r $APPDATA\XMLmind\XMLEditor8\addon\XLingPap
    RmDir /r $INSTDIR\XeLaTeX
    RmDir /r $INSTDIR\XXE
    ; RmDir /r $INSTDIR\XLingPaperSamples
    DeleteRegValue HKLM "${REGKEY}\Components" Main
       ; delete environment variables
   DeleteRegValue ${env_hklm} XLingPaperXeLaTeXPath
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
   DeleteRegValue ${env_hklm} XLingPaperXXEBinPath
   ; make sure windows knows about the change
   SendMessage ${HWND_BROADCAST} ${WM_WININICHANGE} 0 "STR:Environment" /TIMEOUT=5000
SectionEnd

Section -un.post UNSEC0001
    DeleteRegKey HKLM "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\$(^Name)"
    Delete "$SMPROGRAMS\$StartMenuGroup\Launch XXE To Edit an XLingPaper Document.lnk"
    Delete "$SMPROGRAMS\$StartMenuGroup\New XLingPaper Paper.lnk"
    Delete "$SMPROGRAMS\$StartMenuGroup\New XLingPaper Book.lnk" 
    Delete "$SMPROGRAMS\$StartMenuGroup\New XLingPaper References.lnk"
    Delete "$SMPROGRAMS\$StartMenuGroup\Uninstall $(^Name).lnk"
    RmDir $SMPROGRAMS\$StartMenuGroup
    Delete $INSTDIR\XLingPaperUninstall.exe
    DeleteRegValue HKLM "${REGKEY}" Path
    DeleteRegKey /IfEmpty HKLM "${REGKEY}\Components"
    DeleteRegKey /IfEmpty HKLM "${REGKEY}"
    RmDir $INSTDIR
SectionEnd

# Installer functions
Function .onInit
    InitPluginsDir
    StrCpy $StartMenuGroup XLingPaper
FunctionEnd

# Uninstaller functions
Function un.onInit
    ReadRegStr $INSTDIR HKLM "${REGKEY}" Path
    StrCpy $StartMenuGroup XLingPaper
    !insertmacro SELECT_UNSECTION Main ${UNSEC0000}
FunctionEnd


; launch XXE with our sample paper in it (and also setting some XXE preferences)
Function launchXXEWithSamplePaper
        # try to run XXE while setting the preferences we need
    Exec '$XXE_command_line -putprefs "$INSTDIR\XXE\XLingPaper.preferences" "$DOCUMENTS\My XLingPaper\SamplePaper.xml"'
FunctionEnd

